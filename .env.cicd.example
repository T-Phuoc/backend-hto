COMPOSE_PROJECT_NAME=backend-hto-qlnb
APP_IMAGE=backend-hto-qlnb:local
APP_CONTAINER_NAME=backend-hto-qlnb-app
APP_PORT=3006
CONTAINER_PORT=8080
NODE_ENV=production
TZ=Asia/Ho_Chi_Minh
HEALTHCHECK_PATH=/api/v1/health

# Optional: pass application secrets from another env file on the server.
APP_ENV_FILE=.env

# MongoDB Atlas / external MongoDB. Put the real value in the server .env file,
# not in git.
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/hito_crm?appName=HTO-internal
DATABASE_NAME=hito_crm

# Optional local MongoDB service. Enable with: COMPOSE_PROFILES=mongo
MONGO_INITDB_ROOT_USERNAME=backend_hto
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_INITDB_DATABASE=hito_crm
MONGO_PORT=27017

# Optional Redis service. Enable with: COMPOSE_PROFILES=redis
REDIS_PORT=6379
